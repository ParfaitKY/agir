{
  "expo": {
    "name": "MyCedaici",
    "slug": "ZenithMobileV2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon_cedaici.jpg",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/cedaici-transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1220"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-cedaici.jpg",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.cedaici.mobile",
      "versionCode": 2
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "dbd6ac2a-1434-40a4-be56-e02bc58ff82a"
      }
    }
  }
}
