{
  "expo": {
    "name": "MyCedaici",
    "slug": "ZenithMobileV2",
    "scheme": "cedaici",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ICON-PHONE.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/cedaici-transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1220"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cedaici.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/ICON-PHONE.png",
        "backgroundColor": "#000000"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.cedaici.mobile",
      "versionCode": 2,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [{ "scheme": "cedaici" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-secure-store"],
    "extra": {
      "eas": {
        "projectId": "dbd6ac2a-1434-40a4-be56-e02bc58ff82a"
      }
    }
  }
}
