{
  "expo": {
    "name": "MyCedaici",
    "slug": "ZenithMobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon_cedaici.jpg",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/cedaici-transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1220"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-cedaici.jpg",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.cedaici.mobile",
      "versionCode": 2
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-secure-store"],
    "extra": {
      "eas": {
        "projectId": "af007b25-5163-4aeb-862e-adc47c815ab4"
      }
    }
  }
}
